<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="PersianDownloadManager.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:PersianDownloadManager.Views"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <ScrollView Margin="{ThemeResource ContentPageMargin}" Padding="{ThemeResource ContentPagePadding}" HorizontalAlignment="Stretch" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10" dev:PanelAttach.ChildrenTransitions="Default" Spacing="5">
            <dev:SettingsCard x:Name="GeneralCard" x:Uid="SettingsPageGeneral" Command="{x:Bind local:SettingsWindow.Instance.NavigateToCommand}" CommandParameter="{x:Bind GeneralParam, Mode=OneWay}" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/General.png}" IsClickEnabled="True" />
            <dev:SettingsCard x:Name="DownloadCard" x:Uid="SettingsPageDownload" Command="{x:Bind local:SettingsWindow.Instance.NavigateToCommand}" CommandParameter="{x:Bind DownloadParam, Mode=OneWay}" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Download.png}" IsClickEnabled="True" />
            <dev:SettingsCard x:Name="ThemeCard" x:Uid="SettingsPageTheme" Command="{x:Bind local:SettingsWindow.Instance.NavigateToCommand}" CommandParameter="{x:Bind ThemeParam, Mode=OneWay}" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Theme.png}" IsClickEnabled="True" />
            <dev:SettingsCard x:Name="UpdateCard" x:Uid="SettingsPageUpdate" Command="{x:Bind local:SettingsWindow.Instance.NavigateToCommand}" CommandParameter="{x:Bind UpdateParam, Mode=OneWay}" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Update.png}" IsClickEnabled="True" />
            <dev:SettingsCard x:Name="AboutCard" x:Uid="SettingsPageAbout" Command="{x:Bind local:SettingsWindow.Instance.NavigateToCommand}" CommandParameter="{x:Bind AboutParam, Mode=OneWay}" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Info.png}" IsClickEnabled="True" />
        </StackPanel>
    </ScrollView>
</Page>
