<?xml version="1.0" encoding="utf-8" ?>
<dev:ContentDialogWindow x:Class="PersianDownloadManager.Views.PropertiesDialog"
                         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:dev="using:DevWinUI"
                         xmlns:local="using:PersianDownloadManager.Views"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         x:Uid="PropertiesDialog"
                         MinWidth="500"
                         MinHeight="400"
                         MaxWidth="700"
                         MaxHeight="600"
                         Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                         CanResize="False"
                         DefaultButton="Primary"
                         PrimaryButtonClick="ContentDialogWindow_PrimaryButtonClick"
                         SecondaryButtonClick="ContentDialogWindow_SecondaryButtonClick"
                         mc:Ignorable="d">
    <dev:ContentDialogWindow.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </dev:ContentDialogWindow.SystemBackdrop>

    <Grid Padding="0,10,0,0" ColumnSpacing="5" FlowDirection="LeftToRight" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Image Width="28" Height="28" Source="{x:Bind Item.Icon, Mode=OneWay}" />
        <TextBlock x:Name="TxtFileInfo" Grid.Column="1" Margin="10,0" VerticalAlignment="Center" Style="{ThemeResource BaseTextBlockStyle}" Text="{x:Bind Item.FileName, Mode=OneWay}" TextWrapping="Wrap" />

        <NavigationViewItemSeparator Grid.Row="1" Grid.ColumnSpan="2" />

        <InfoBar x:Name="StatusInfoBar" Title="{x:Bind Item.FileInfo, Mode=OneWay}" Grid.Row="2" Grid.ColumnSpan="2" IsClosable="False" IsOpen="True" Message="{x:Bind Item.Size, Mode=OneWay}" />
        <TextBox Grid.Row="3" Grid.ColumnSpan="2" VerticalAlignment="Bottom" Header="File Path" IsReadOnly="True" Text="{x:Bind Item.FilePath, Mode=OneWay}" />

    </Grid>
</dev:ContentDialogWindow>
