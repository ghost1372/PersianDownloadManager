<?xml version="1.0" encoding="utf-8" ?>
<dev:ContentDialogWindow x:Class="PersianDownloadManager.Views.SpeedLimitDialog"
                         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:common="using:PersianDownloadManager.Common"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:dev="using:DevWinUI"
                         xmlns:local="using:PersianDownloadManager.Views"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         x:Uid="SpeedLimitDialog"
                         MaxWidth="600"
                         Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                         CanResize="False"
                         CloseButtonClick="ContentDialogWindow_CloseButtonClick"
                         DefaultButton="Primary"
                         PrimaryButtonClick="ContentDialogWindow_PrimaryButtonClick"
                         mc:Ignorable="d">
    <dev:ContentDialogWindow.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </dev:ContentDialogWindow.SystemBackdrop>
    <StackPanel Spacing="10">
        <TextBlock x:Uid="SpeedLimitDialog_TitleBlock" Style="{ThemeResource TitleTextBlockStyle}" />
        <TextBlock x:Uid="SpeedLimitDialog_DescriptionBlock" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{ThemeResource BaseTextBlockStyle}" TextWrapping="Wrap" />
        <NumberBox x:Name="NBLimit" Minimum="0" SmallChange="2560" SpinButtonPlacementMode="Inline" ValueChanged="NumberBox_ValueChanged" />
        <InfoBar x:Name="LimitInfoBar" IsClosable="False" IsOpen="True" />
    </StackPanel>
</dev:ContentDialogWindow>
