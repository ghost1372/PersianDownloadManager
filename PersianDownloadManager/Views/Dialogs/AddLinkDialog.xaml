<?xml version="1.0" encoding="utf-8" ?>
<dev:ContentDialogWindow x:Class="PersianDownloadManager.Views.AddLinkDialog"
                         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:dev="using:DevWinUI"
                         xmlns:local="using:PersianDownloadManager.Views"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         x:Uid="AddLinkDialog"
                         MinWidth="600"
                         Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                         CanResize="False"
                         CloseButtonClick="ContentDialogWindow_CloseButtonClick"
                         DefaultButton="Primary"
                         PrimaryButtonClick="ContentDialogWindow_PrimaryButtonClick"
                         mc:Ignorable="d">
    <dev:ContentDialogWindow.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </dev:ContentDialogWindow.SystemBackdrop>

    <Grid>
        <TextBox x:Name="TxtLink" x:Uid="AddLinkDialogText" />
    </Grid>
</dev:ContentDialogWindow>
