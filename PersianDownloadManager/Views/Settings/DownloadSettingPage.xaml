<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="PersianDownloadManager.Views.DownloadSettingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:common="using:PersianDownloadManager.Common"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:PersianDownloadManager.Views"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      dev:BreadcrumbNavigator.IsHeaderVisible="True"
      mc:Ignorable="d">

    <ScrollView Margin="{ThemeResource ContentPageMargin}" Padding="{ThemeResource ContentPagePadding}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10" dev:PanelAttach.ChildrenTransitions="Default" Spacing="5">

            <InfoBar x:Uid="DownloadSettingPage_ResetInfoBar" IsClosable="False" IsOpen="True" Severity="Informational">
                <InfoBar.ActionButton>
                    <Button x:Uid="DownloadSettingPage_ResetButton" Command="{x:Bind ViewModel.ResetSettingsCommand}" />
                </InfoBar.ActionButton>
            </InfoBar>

            <dev:SettingsExpander x:Uid="DownloadSettingPage_SaveLocation" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/DownloadFolder.png}">
                <Button x:Uid="DownloadSettingPage_Browse" MinWidth="220" Command="{x:Bind ViewModel.ChooseFolderCommand}" />
                <dev:SettingsExpander.ItemsHeader>
                    <HyperlinkButton HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Command="{x:Bind ViewModel.GoToFolderInExplorerCommand}" Content="{x:Bind ViewModel.DownloadFolderPath, Mode=OneWay}" FlowDirection="LeftToRight" />
                </dev:SettingsExpander.ItemsHeader>
            </dev:SettingsExpander>

            <!--  Performance  -->
            <dev:SettingsExpander x:Uid="DownloadSettingPage_Performance" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Performance.png}">

                <dev:SettingsExpander.Items>
                    <dev:SettingsCard x:Uid="DownloadSettingPage_BufferBlockSize" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Block.png}">
                        <NumberBox MinWidth="200" Minimum="0" SpinButtonPlacementMode="Inline" Value="{x:Bind common:AppHelper.DownloadEngineSettings.BufferBlockSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>
                    <dev:SettingsCard x:Uid="DownloadSettingPage_ChunkCount" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Chunk.png}">
                        <NumberBox MinWidth="200" Minimum="1" SpinButtonPlacementMode="Inline" Value="{x:Bind common:AppHelper.DownloadEngineSettings.ChunkCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="DownloadSettingPage_MinimumSizeOfChunking" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Chunk.png}">
                        <NumberBox MinWidth="200" Minimum="0" SpinButtonPlacementMode="Inline" Value="{x:Bind ViewModel.MinimumSizeOfChunking, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="DownloadSettingPage_MinimumChunkSize" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Chunk.png}">
                        <NumberBox MinWidth="200" Minimum="0" SpinButtonPlacementMode="Inline" Value="{x:Bind ViewModel.MinimumChunkSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="DownloadSettingPage_ParallelDownload" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Parallel.png}">
                        <ToggleSwitch x:Name="TGParallelDownload" IsOn="{x:Bind common:AppHelper.DownloadEngineSettings.ParallelDownload, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="DownloadSettingPage_ParallelCount" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Parallel.png}" IsEnabled="{x:Bind TGParallelDownload.IsOn, Mode=OneWay}">
                        <NumberBox MinWidth="200" Minimum="0" SpinButtonPlacementMode="Inline" Value="{x:Bind common:AppHelper.DownloadEngineSettings.ParallelCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>

                </dev:SettingsExpander.Items>

            </dev:SettingsExpander>

            <dev:SettingsExpander x:Uid="DownloadSettingPage_Network" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Network.png}">
                <dev:SettingsExpander.Items>
                    <dev:SettingsCard x:Uid="DownloadSettingPage_MaximumBytesPerSecond" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Speed.png}">
                        <NumberBox x:Name="NBLimit" MinWidth="200" Minimum="0" SmallChange="2560" SpinButtonPlacementMode="Inline" ValueChanged="NumberBox_ValueChanged" Value="{x:Bind ViewModel.MaximumBytesPerSecond, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="DownloadSettingPage_MaxTryAgainOnFailure" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Close.png}">
                        <NumberBox MinWidth="200" Maximum="20" Minimum="1" SpinButtonPlacementMode="Inline" Value="{x:Bind common:AppHelper.DownloadEngineSettings.MaxTryAgainOnFailure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="DownloadSettingPage_BlockTimeout" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Timeout.png}">
                        <NumberBox MinWidth="200" Minimum="0" SpinButtonPlacementMode="Inline" Value="{x:Bind common:AppHelper.DownloadEngineSettings.BlockTimeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="DownloadSettingPage_HttpClientTimeout" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Timeout.png}">
                        <NumberBox MinWidth="200" Minimum="0" SpinButtonPlacementMode="Inline" Value="{x:Bind common:AppHelper.DownloadEngineSettings.HttpClientTimeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>
                </dev:SettingsExpander.Items>
            </dev:SettingsExpander>
            <dev:SettingsExpander x:Uid="DownloadSettingPage_Memory" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Memory.png}">
                <dev:SettingsExpander.Items>
                    <dev:SettingsCard x:Uid="DownloadSettingPage_MaximumMemoryBufferBytes" CornerRadius="4,4,0,0" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Memory.png}">
                        <NumberBox MinWidth="200" Minimum="0" SpinButtonPlacementMode="Inline" Value="{x:Bind ViewModel.MaximumMemoryBufferBytes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>
                    <InfoBar x:Uid="DownloadSettingPage_MaximumMemoryBufferBytesInfoBar" IsClosable="False" IsOpen="True" />
                    <InfoBar x:Uid="DownloadSettingPage_MaximumMemoryBufferBytesInfoBar2" IsClosable="False" IsOpen="True" Severity="Warning" />
                </dev:SettingsExpander.Items>
            </dev:SettingsExpander>

            <dev:SettingsExpander x:Uid="DownloadSettingPage_Resume" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Document.png}">
                <dev:SettingsExpander.Items>
                    <dev:SettingsCard x:Uid="DownloadSettingPage_EnableAutoResumeDownload" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/AutoResume.png}">
                        <ToggleSwitch IsOn="{x:Bind common:AppHelper.DownloadEngineSettings.EnableAutoResumeDownload, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="DownloadSettingPage_DownloadFileExtension" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Extension.png}">
                        <TextBox MinWidth="200" PlaceholderText=".download" Text="{x:Bind ViewModel.DownloadFileExtension, Mode=TwoWay}" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="DownloadSettingPage_FileExistPolicy" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Policy.png}">
                        <ComboBox x:Name="CmbFileExistPolicy" MinWidth="200" ItemsSource="{x:Bind ViewModel.FileExistPolicy, Mode=OneWay}" SelectedIndex="{x:Bind ViewModel.FileExistPolicySelectedIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </dev:SettingsCard>
                </dev:SettingsExpander.Items>

            </dev:SettingsExpander>

            <dev:SettingsCard x:Uid="DownloadSettingPage_ClearPackageOnCompletionWithFailure" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Delete.png}">
                <ToggleSwitch IsOn="{x:Bind common:AppHelper.DownloadEngineSettings.ClearPackageOnCompletionWithFailure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </dev:SettingsCard>
        </StackPanel>
    </ScrollView>
</Page>
