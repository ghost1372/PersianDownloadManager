<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="PersianDownloadManager.Views.GeneralSettingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:common="using:PersianDownloadManager.Common"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:PersianDownloadManager.Views"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      dev:BreadcrumbNavigator.IsHeaderVisible="True"
      mc:Ignorable="d">

    <ScrollView Margin="{ThemeResource ContentPageMargin}" Padding="{ThemeResource ContentPagePadding}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10" dev:PanelAttach.ChildrenTransitions="Default" Spacing="5">
            <dev:SettingsCard x:Uid="GeneralSettingPage_UseShellIcons" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Shell.png}">
                <ToggleSwitch IsOn="{x:Bind common:AppHelper.Settings.UseWindowsShellIcons, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </dev:SettingsCard>

            <dev:SettingsCard x:Uid="GeneralSettingPage_Language" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Language.png}">
                <ComboBox x:Name="CmbLanguage" MinWidth="250" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ItemsSource="{x:Bind dev:AppLanguageHelper.SupportedLanguages}" SelectedIndex="{x:Bind ViewModel.SelectedAppLanguageIndex, Mode=TwoWay}" SelectionChanged="CmbLanguage_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="dev:AppLanguageItem">
                            <TextBlock Style="{ThemeResource BaseTextBlockStyle}" Text="{x:Bind Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </dev:SettingsCard>

            <dev:SettingsCard x:Name="FontCard" x:Uid="GeneralSettingPage_UIFont" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Font.png}">
                <ComboBox x:Name="CmbUIFont" MinWidth="250" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ItemsSource="{x:Bind common:FontHelper.UIFonts, Mode=OneWay}" SelectionChanged="OnUIFontSelectionChanged" />
            </dev:SettingsCard>

            <dev:SettingsCard x:Uid="GeneralSettingPage_AutoStartup" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/Startup.png}">
                <ToggleSwitch IsOn="{x:Bind dev:StartupHelper.IsAppStartupWithWindowsForXamlBindingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </dev:SettingsCard>

            <dev:SettingsExpander x:Uid="GeneralSettingPage_Debug" HeaderIcon="{dev:BitmapIcon Source=Assets/Fluent/DevMode.png}">
                <ToggleSwitch IsOn="{x:Bind common:AppHelper.Settings.UseDeveloperMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <dev:SettingsExpander.ItemsHeader>
                    <HyperlinkButton HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="NavigateToLogPath_Click" Content="{x:Bind common:Constants.LogDirectoryPath}" FlowDirection="LeftToRight" />
                </dev:SettingsExpander.ItemsHeader>
            </dev:SettingsExpander>
            <TeachingTip x:Uid="RestartNotificationText" IsLightDismissEnabled="True" IsOpen="{x:Bind ViewModel.ShowRestartForLanguage, Mode=TwoWay}" Target="{x:Bind CmbLanguage}">
                <StackPanel Padding="0,8,0,0" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                    <Button x:Uid="YesButton" MinWidth="140" Command="{x:Bind ViewModel.RestartCommand}" Style="{ThemeResource AccentButtonStyle}" />
                    <Button x:Uid="NoButton" MinWidth="140" Command="{x:Bind ViewModel.CancelRestartCommand}" />
                </StackPanel>
            </TeachingTip>
            <TeachingTip x:Uid="RestartNotificationText" IsLightDismissEnabled="True" IsOpen="{x:Bind ViewModel.ShowRestartForFont, Mode=TwoWay}" Target="{x:Bind CmbUIFont}">
                <StackPanel Padding="0,8,0,0" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                    <Button x:Uid="YesButton" MinWidth="140" Command="{x:Bind ViewModel.RestartCommand}" Style="{ThemeResource AccentButtonStyle}" />
                    <Button x:Uid="NoButton" MinWidth="140" Command="{x:Bind ViewModel.CancelRestartCommand}" />
                </StackPanel>
            </TeachingTip>
        </StackPanel>
    </ScrollView>
</Page>
