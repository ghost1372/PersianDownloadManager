<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="PersianDownloadManager.Views.AboutUsSettingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:common="using:PersianDownloadManager.Common"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:PersianDownloadManager.Views"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      dev:BreadcrumbNavigator.IsHeaderVisible="True"
      mc:Ignorable="d">

    <ScrollView Margin="{ThemeResource ContentPageMargin}" Padding="{ThemeResource ContentPagePadding}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10" dev:PanelAttach.ChildrenTransitions="Default" Spacing="5">
            <dev:SettingsExpander x:Uid="AboutUsSettingPage_About" HeaderIcon="{dev:BitmapIcon Source=Assets/AppIcon.png}" IsExpanded="True">
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsTextSelectionEnabled="True" Text="{x:Bind dev:ProcessInfoHelper.VersionWithPrefix}" />
                <dev:SettingsExpander.Items>
                    <dev:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                        <StackPanel Orientation="Vertical" Spacing="5">
                            <TextBlock x:Uid="AboutUsSettingPage_RelatedLink" />
                            <HyperlinkButton x:Uid="AboutUsSettingPage_SourceCode" NavigateUri="{x:Bind common:Constants.RepoUrl, Mode=OneWay}" />
                            <HyperlinkButton x:Uid="AboutUsSettingPage_ReleaseNote" NavigateUri="{x:Bind common:Constants.RepoReleaseUrl, Mode=OneWay}" />
                        </StackPanel>
                    </dev:SettingsCard>
                </dev:SettingsExpander.Items>
            </dev:SettingsExpander>
        </StackPanel>
    </ScrollView>
</Page>
