<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="PersianDownloadManager.Views.DownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:dev="using:DevWinUI"
        xmlns:local="using:PersianDownloadManager.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <Grid x:Uid="FlowDirection" Loaded="Grid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TitleBar x:Name="AppTitleBar" Title="{x:Bind WindowTitle}" FlowDirection="LeftToRight">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/AppIcon.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1" Padding="30,5,30,10" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}" ColumnSpacing="10" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <TextBox x:Uid="DownloadWindow_URL" Grid.ColumnSpan="3" VerticalAlignment="Top" IsReadOnly="True" PlaceholderText="https//localhost.com/Test.zip" Text="{x:Bind Url, Mode=OneWay}" />

            <Grid Grid.Row="1" Grid.ColumnSpan="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSaveAs" x:Uid="DownloadWindow_SaveAs" VerticalAlignment="Center" PlaceholderText="C:\Downloads\Test.zip" />
                <Button x:Name="BtnSaveFile" Grid.Column="1" Margin="10,0,0,2" VerticalAlignment="Bottom" Click="BtnSaveFile_Click">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <ImageIcon Width="18" Height="18" Margin="0,0,0,-5" Source="ms-appx:///Assets/Fluent/FilePicker.png" />
                        <TextBlock Text="..." />
                    </StackPanel>
                </Button>
                <AppBarSeparator Grid.Column="2" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Stretch" />
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="10">
                    <Image x:Name="ImgIcon" Width="32" Height="32" Source="ms-appx:///Assets/Fluent/Extensions/File.png" />
                    <TextBlock x:Name="TxtFileSize" HorizontalAlignment="Center" Style="{ThemeResource BaseTextBlockStyle}" />
                </StackPanel>
            </Grid>
            <NavigationViewItemSeparator Grid.Row="2" Grid.ColumnSpan="3" VerticalAlignment="Top" />
            <Button x:Uid="DownloadWindow_DownloadLater" Grid.Row="2" HorizontalAlignment="Stretch" Click="OnDownloadLater" Content="Download Later" />
            <Button x:Uid="DownloadWindow_StartDownload" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnStartDownload" />
            <Button x:Uid="DownloadWindow_CancelDownload" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Stretch" Click="OnCancelDownload" />

        </Grid>
    </Grid>
</Window>
