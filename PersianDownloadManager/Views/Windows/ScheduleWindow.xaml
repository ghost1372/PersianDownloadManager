<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="PersianDownloadManager.Views.ScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="using:PersianDownloadManager.Common"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:PersianDownloadManager.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tv="using:WinUI.TableView"
        mc:Ignorable="d">


    <Grid x:Uid="FlowDirection" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TitleBar x:Name="AppTitleBar" Title="{x:Bind WindowTitle}" FlowDirection="LeftToRight">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/AppIcon.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1" Padding="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TabView VerticalAlignment="Stretch" IsAddTabButtonVisible="False">
                <TabView.TabItems>
                    <TabViewItem x:Uid="ScheduleWindow_ScheduleTab" IsClosable="False">
                        <TabViewItem.IconSource>
                            <ImageIconSource ImageSource="ms-appx:///Assets/Fluent/Schedule.png" />
                        </TabViewItem.IconSource>
                        <StackPanel Grid.ColumnSpan="3" Padding="20" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}" Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <CheckBox x:Name="ChkStartTime" x:Uid="ScheduleWindow_StartDownloadTime" Checked="ChkStartTime_Checked" Unchecked="ChkStartTime_Checked" />
                                <TimePicker IsEnabled="{x:Bind ChkStartTime.IsChecked.Value, Mode=OneWay}" SelectedTime="{x:Bind common:AppHelper.Settings.ScheduleStartTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <NavigationViewItemSeparator />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <CheckBox x:Name="ChkStopTime" x:Uid="ScheduleWindow_StopDownloadTime" Checked="ChkStopTime_Checked" Unchecked="ChkStopTime_Checked" />
                                <TimePicker IsEnabled="{x:Bind ChkStopTime.IsChecked.Value, Mode=OneWay}" SelectedTime="{x:Bind common:AppHelper.Settings.ScheduleStopTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <NavigationViewItemSeparator />
                            <NavigationViewItemSeparator />
                            <CheckBox x:Uid="ScheduleWindow_ClosePdmAfterDownloads" IsChecked="{x:Bind common:AppHelper.Settings.IsScheduleClosePDMEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox x:Name="ChkShutdown" x:Uid="ScheduleWindow_ShutdownAfterDownloads" IsChecked="{x:Bind common:AppHelper.Settings.IsScheduleShutdownEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox x:Uid="ScheduleWindow_ForceCloseApps" Margin="20,0" IsChecked="{x:Bind common:AppHelper.Settings.IsScheduleForceCloseAppEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{x:Bind ChkShutdown.IsChecked.Value, Mode=OneWay}" />
                        </StackPanel>
                    </TabViewItem>
                    <TabViewItem x:Uid="ScheduleWindow_QueueFilesTab" IsClosable="False">
                        <TabViewItem.IconSource>
                            <ImageIconSource ImageSource="ms-appx:///Assets/Fluent/Queue.png" />
                        </TabViewItem.IconSource>
                        <Grid Padding="20" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <NumberBox x:Uid="ScheduleWindow_ConcurrentDownload" MinWidth="200" HorizontalAlignment="Left" Maximum="20" Minimum="1" SpinButtonPlacementMode="Inline" Value="{x:Bind common:AppHelper.Settings.ScheduleConcurrentCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <tv:TableView x:Name="ScheduleTableView" Grid.Row="1" AllowDrop="True" AutoGenerateColumns="False" CanDragItems="True" CanReorderItems="True" CornerButtonMode="SelectAll" IsReadOnly="True" ItemsSource="{x:Bind ViewModel.Downloads, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="ScheduleTableView_SelectionChanged" SelectionUnit="Row">
                                <tv:TableView.Columns>
                                    <tv:TableViewTextColumn Binding="{Binding Index}" CanFilter="False" Header="#" />
                                    <tv:TableViewTemplateColumn x:Uid="TvFileName" MinWidth="200" CanFilter="True" CanSort="True">
                                        <tv:TableViewTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="5,0" Orientation="Horizontal" Spacing="5">
                                                    <Image Width="24" Height="24" Source="{Binding Icon}" />
                                                    <TextBlock VerticalAlignment="Center" Style="{ThemeResource BaseTextBlockStyle}" Text="{Binding FileName}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </tv:TableViewTemplateColumn.CellTemplate>
                                    </tv:TableViewTemplateColumn>
                                    <tv:TableViewTextColumn x:Uid="TvFileSize" Width="80" Binding="{Binding Size}" SortMemberPath="TotalBytes" />
                                    <tv:TableViewTemplateColumn x:Uid="TvStatus" MinWidth="200" CanFilter="True" CanSort="True" SortMemberPath="Status">
                                        <tv:TableViewTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="10,0" Spacing="5">
                                                    <TextBlock FontSize="12" Style="{ThemeResource BaseTextBlockStyle}" Text="{Binding StatusTextWithPercent}" />
                                                    <ProgressBar ShowError="{Binding ShowError}" Visibility="{Binding ShowProgressBar, Converter={StaticResource BoolToVisibilityConverter}}" Value="{Binding Progress}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </tv:TableViewTemplateColumn.CellTemplate>
                                    </tv:TableViewTemplateColumn>
                                    <tv:TableViewTextColumn x:Uid="TvRemainingTime" Width="150" Binding="{Binding RemainingTime}" />
                                </tv:TableView.Columns>
                            </tv:TableView>
                            <Border Grid.Row="2" Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource ControlCornerRadius}" />
                            <CommandBar Grid.Row="2" HorizontalAlignment="Left" OverflowButtonVisibility="Collapsed">
                                <AppBarButton Width="50" Command="{x:Bind ViewModel.MoveDownCommand}" Label="Down">
                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE74B;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                                <AppBarButton Width="50" Command="{x:Bind ViewModel.MoveUpCommand}" Label="Up">
                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE74A;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                                <AppBarButton Width="50" Command="{x:Bind ViewModel.DeleteCommand}" Label="Delete">
                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE894;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                            </CommandBar>
                        </Grid>
                    </TabViewItem>
                </TabView.TabItems>

            </TabView>
            <Grid Grid.Row="1" Padding="20,20,20,20" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnStart" x:Uid="ScheduleWindow_StartButton" HorizontalAlignment="Stretch" Click="OnStartClick" IsEnabled="{Binding BtnStart.IsEnabled, Converter={StaticResource BoolNegationConverter}, Mode=OneWay}" Style="{ThemeResource AccentButtonStyle}" />
                <Button x:Name="BtnStop" x:Uid="ScheduleWindow_StopButton" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnStopClick" IsEnabled="{Binding BtnStop.IsEnabled, Converter={StaticResource BoolNegationConverter}, Mode=OneWay}" />
                <Button x:Uid="ScheduleWindow_CloseButton" Grid.Column="2" HorizontalAlignment="Stretch" Click="OnCloseClick" />
            </Grid>

        </Grid>
    </Grid>
</Window>
